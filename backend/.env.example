# ── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Firebase Admin SDK ────────────────────────────────
# Option A: Path to downloaded service account JSON
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Option B: Individual fields (for CI/CD / Docker secrets)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# Firestore database URL (only needed for Realtime Database)
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# Firebase Storage bucket
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# ── Security ──────────────────────────────────────────
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://your-production-domain.com

# Rate limiting (requests per minute per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Internal service API key (server-to-server calls)
INTERNAL_API_KEY=change-me-in-production

# ── Analytics cron schedule (cron syntax) ─────────────
CRON_STOCK_CHECK=0 * * * *        # every hour
CRON_APPROVAL_CHECK=0 */6 * * *   # every 6 hours
CRON_ANALYTICS_REFRESH=0 0 * * *  # midnight daily

# ── Email Notifications (optional) ───────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@campus.edu
SMTP_PASS=your-smtp-password
SMTP_FROM="CITIL Platform <notifications@campus.edu>"
